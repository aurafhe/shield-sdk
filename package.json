{
  "name": "@aura/shield-sdk",
  "version": "0.2.0",
  "description": "TypeScript client SDK for the Aura Fully Homomorphic Encryption service",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["fhe", "encryption", "privacy", "homomorphic"],
  "author": "Aura FHE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aurafhe/shield-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/aurafhe/shield-sdk/issues"
  },
  "homepage": "https://github.com/aurafhe/shield-sdk#readme",
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}
